# Скопируй этот файл в .env и заполни значения.
# .env НЕ коммитится в git (он в .gitignore).

# Токен бота от @BotFather в Telegram
TELEGRAM_BOT_TOKEN=123456789:AA-your-telegram-bot-token

# API-ключ из Google AI Studio (https://aistudio.google.com/apikey)
GEMINI_API_KEY=your-google-ai-studio-key

# (опционально) другая модель Nano Banana — обычно менять не нужно
# GEMINI_MODEL=gemini-2.5-flash-image
